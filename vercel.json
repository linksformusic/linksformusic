{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs"
    },
    "dashboard": {
      "root": "apps/dashboard",
      "framework": "nextjs"
    },
    "api": {
      "root": "apps/api",
      "framework": "express",
      "entrypoint": "src/index.ts"
    }
  },
  "experimentalServices": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs"
    },
    "dashboard": {
      "root": "apps/dashboard",
      "framework": "nextjs"
    },
    "api": {
      "root": "apps/api",
      "framework": "express",
      "entrypoint": "src/index.ts"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "dashboard.linksformusic.com" }],
      "destination": { "service": "dashboard" }
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "api.linksformusic.com" }],
      "destination": { "service": "api" }
    },
    {
      "source": "/(.*)",
      "destination": { "service": "web" }
    }
  ]
}
